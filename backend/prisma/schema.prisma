generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Store {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  website  String
  logoUrl  String?
  listings Listing[]
}

model Vehicle {
  id       Int       @id @default(autoincrement())
  brand    String
  model    String
  listings Listing[]

  @@unique([brand, model])
}

model PartCategory {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  listings Listing[]
}

model Listing {
  id           Int          @id @default(autoincrement())
  title        String
  price        Float
  currency     String       @default("MKD")
  availability String
  productUrl   String       @unique
  lastUpdated  DateTime     @updatedAt

  store        Store        @relation(fields: [storeId], references: [id])
  storeId      Int

  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id])
  vehicleId    Int

  category     PartCategory @relation(fields: [categoryId], references: [id])
  categoryId   Int
}
